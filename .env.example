HUGGINGFACEHUB_API_TOKEN=Your_HuggingFace_API_Token
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_PROVIDER=auto
MAX_NEW_TOKENS=256
TEMPERATURE=0.2
DO_SAMPLE=false
SUMMARY_EVERY_N_TURNS=3
RECENT_WINDOW_TURNS=4
MAX_TOOL_STEPS=3

# Agent driver selection (see DriverInterface.md). All four benchmarks build
# the agent under test through this driver — a registry key (e.g.
# research_helper) or a raw "pkg.module:ClassName" import path for an
# external agent's driver. Unset = research_helper.
AGENT_DRIVER=research_helper
# Optional overrides for result attribution (see ResultFormat.md). AGENT_NAME
# is the label recorded in the experiment index / summary.json; when set it
# OVERRIDES the driver's own name (else the driver name is used). MEMORY_ARCHITECTURE
# buckets results/<arch>/.
#AGENT_NAME=research_helper
#MEMORY_ARCHITECTURE=default

# AdaMem agent drivers (see AdaMemDrivers.md). Set AGENT_DRIVER to one of
# adamem_flat_rag | adamem_episodic | adamem_mem1 to benchmark the external
# memory-strategy agents in Agents/AdaMemAgents/. These are memory-QA agents
# with no tool support — only LoCoMo and LongMemEval apply (BFCL/ToolSandbox
# fail fast). Each defaults MEMORY_ARCHITECTURE to its strategy. All settings
# below are optional (agent defaults shown).
#ADAMEM_OLLAMA_MODEL=qwen3-14b-32k:latest
#ADAMEM_OLLAMA_HOST=http://127.0.0.1:11434
#ADAMEM_MAX_TOKENS=512
#ADAMEM_TEMPERATURE=0.2
#ADAMEM_TIMEOUT=120
# Prompt policy for the agent's QA system prompt:
#   merge     = (default) keep the agent's own prompt + append the benchmark's
#               answer-format contract under a "highest priority" header.
#   native    = keep each agent's own QA prompt untouched.
#   benchmark = force the harness system prompt (full replace).
#ADAMEM_PROMPT_MODE=merge
# episodic store: :memory: (default) or a file path for persistence.
#ADAMEM_EPISODIC_DB=:memory:
# mem1 only: session (default, one <IS> rewrite per replayed session) or turn.
#ADAMEM_MEM1_INGEST_GRANULARITY=session

# LoCoMo benchmark settings
LOCOMO_DATA_FILE=data/locomo/demo.jsonl
# Controls where benchmark outputs are written.
LOCOMO_OUTPUT_DIR=results/locomo
# Controls whether the benchmark runs one sample or the full batch.
LOCOMO_RUN_MODE=single
# Optional sample id to target in single mode.
LOCOMO_SAMPLE_ID=locomo_001
# Maximum batch size; set to 0 or leave unset to process all samples.
LOCOMO_MAX_SAMPLES=0
# If true, the example script creates demo data before loading.
LOCOMO_CREATE_DEMO_DATA=true
# If true, batch runs print progress to the terminal.
LOCOMO_VERBOSE=true

# ToolSandbox benchmark settings
# Path to the vendored official ToolSandbox repo (contains the tool_sandbox package).
TOOLSANDBOX_OFFICIAL_ROOT=third_party/ToolSandbox-official
# Isolated ToolSandbox venv interpreter used to spawn the worker process.
TOOLSANDBOX_PYTHON=./ToolSandboxEnv/bin/python
# Where ToolSandbox reports are written.
TOOLSANDBOX_OUTPUT_DIR=results/toolsandbox
# `single` runs one scenario, `batch` runs many.
TOOLSANDBOX_RUN_MODE=single
# Optional exact scenario name to target in single mode (e.g. cellular_off).
TOOLSANDBOX_SCENARIO=cellular_off
# Optional category filter for batch runs.
TOOLSANDBOX_SCENARIO_CATEGORY=
# Use the official milestone scorer (recommended).
TOOLSANDBOX_USE_OFFICIAL_EVAL=true
# Optional comma-separated tool allow-list override; empty = use each scenario's own list.
TOOLSANDBOX_ALLOW_TOOLS=
# Hard cap on conversation turns per scenario.
TOOLSANDBOX_MAX_TURNS=20
# Maximum scenarios for batch runs; 0 = no cap.
TOOLSANDBOX_MAX_SCENARIOS=0
# User simulator: `scripted` (default, no external creds) or `gpt-4o`/`gpt-4`/`gpt-3.5`.
TOOLSANDBOX_USER_MODE=scripted
# API key for the official GPT user simulator. Kept separate from the
# local-model OPENAI_API_KEY placeholder, which will not authenticate.
# Required when TOOLSANDBOX_USER_MODE is not `scripted`.
TOOLSANDBOX_USER_API_KEY=
# Optional OpenAI-compatible endpoint for the user simulator (DeepSeek,
# LiteLLM, vLLM, ...). Empty = https://api.openai.com/v1. The simulator pins
# concrete model names (e.g. gpt-4o-2024-05-13), so a custom endpoint must
# serve or alias the pinned name.
TOOLSANDBOX_USER_BASE_URL=
# If true, RapidAPI-backed search tools (search_lat_lon, search_stock, weather,
# currency, ...) make real web requests; requires RAPID_API_KEY. If false
# (default), the worker installs deterministic offline simulations.
TOOLSANDBOX_REAL_SEARCH_TOOLS=false
# RapidAPI key (https://docs.rapidapi.com/v1.0/docs/keys). Only forwarded to
# the worker when TOOLSANDBOX_REAL_SEARCH_TOOLS=true.
RAPID_API_KEY=
# If true, runs print progress to the terminal.
TOOLSANDBOX_VERBOSE=true


# LongMemEval benchmark settings
# Dataset to run AND the official evaluator's ref_file (question_date differs
# across files, so never mix run/eval files). oracle is the cheap dev dataset.
LONGMEMEVAL_DATA_FILE=third_party/longmemeval-official/data/longmemeval_m_cleaned.json
# Where per-sample + batch reports are written.
LONGMEMEVAL_OUTPUT_DIR=results/longmemeval
# Path to the vendored official LongMemEval repo.
LONGMEMEVAL_OFFICIAL_ROOT=third_party/longmemeval-official
# `single` runs one question, `batch` streams many.
LONGMEMEVAL_RUN_MODE=single
# Target one question by id in single mode; empty = first matching entry.
LONGMEMEVAL_QUESTION_ID=
# Batch cap; 0 = no cap.
LONGMEMEVAL_MAX_SAMPLES=0
# Optional comma-separated question_type filter (e.g. temporal-reasoning,multi-session).
LONGMEMEVAL_QUESTION_TYPES=
# Official LLM judge (evaluate_qa.py) vs local offline heuristic.
LONGMEMEVAL_USE_OFFICIAL_EVAL=true
# Judge model key for evaluate_qa.py: gpt-4o | gpt-4o-mini | llama-3.1-70b-instruct.
LONGMEMEVAL_METRIC_MODEL=gpt-4o
# API key for the LLM judge. Required for gpt-* judge models. Kept separate
# from the project-level OPENAI_API_KEY/OPENAI_BASE_URL, which point at the
# local agent model (Ollama).
LONGMEMEVAL_JUDGE_API_KEY=
# Optional OpenAI-compatible endpoint for the judge (DeepSeek, LiteLLM,
# vLLM, ...). Empty = the real OpenAI API (the judge subprocess strips the
# local OPENAI_BASE_URL). evaluate_qa.py pins concrete model names
# (gpt-4o -> gpt-4o-2024-08-06), so a custom endpoint must serve or alias
# the pinned name.
LONGMEMEVAL_JUDGE_BASE_URL=
# Memory QA needs no tools; keep false.
LONGMEMEVAL_ALLOW_TOOLS=false
# DEBUG-ONLY cap on replayed sessions; 0 = all. When >0, runs are flagged
# sessions_truncated and must NOT be reported as official scores.
LONGMEMEVAL_MAX_SESSIONS=0
# If false (default), per-sample reports collapse history-replay events.
LONGMEMEVAL_FULL_TRAJECTORY=false
# If true, runs print progress to the terminal.
LONGMEMEVAL_VERBOSE=true
